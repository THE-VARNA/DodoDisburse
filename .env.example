# ── Dodo Payments (official env names) ──────────────────────────────────────
DODO_PAYMENTS_API_KEY=sk_test_your_key_here
DODO_PAYMENTS_WEBHOOK_KEY=whsk_your_webhook_signing_secret
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/funding/return
DODO_PAYMENTS_ENVIRONMENT=test_mode

# ── Dodo Product IDs (create these in your Dodo dashboard) ─────────────────
DODO_PRODUCT_50=prd_your_50_product_id
DODO_PRODUCT_100=prd_your_100_product_id
DODO_PRODUCT_250=prd_your_250_product_id
DODO_PRODUCT_500=prd_your_500_product_id

# ── Neon Postgres ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ── Solana (devnet) ──────────────────────────────────────────────────────────
SOLANA_TREASURY_SECRET_KEY=your_base58_treasury_keypair
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Demo (set after running: node scripts/seed.mjs) ──────────────────────────
DEMO_TENANT_ID=your-tenant-uuid-here
NEXT_PUBLIC_DEMO_TENANT_ID=your-tenant-uuid-here
